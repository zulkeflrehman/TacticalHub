rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function admin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function validText(value, minimum, maximum) {
      return value is string && value.size() >= minimum && value.size() <= maximum;
    }

    function lineTotal(items, index) {
      return index < items.size() ? items[index].price * items[index].quantity : 0;
    }

    function itemInventory(items, index) {
      return getAfter(/databases/$(database)/documents/inventory/$(items[index].inventoryId)).data;
    }

    function validOrderItem(items, index, orderId) {
      return index >= items.size() || (
        items[index].keys().hasOnly(['inventoryId', 'productId', 'variantSku', 'name', 'price', 'quantity'])
        && validText(items[index].inventoryId, 1, 500)
        && validText(items[index].productId, 1, 500)
        && validText(items[index].variantSku, 1, 200)
        && validText(items[index].name, 1, 300)
        && items[index].price is int && items[index].price >= 0
        && items[index].quantity is int && items[index].quantity >= 1 && items[index].quantity <= 20
        && itemInventory(items, index).productId == items[index].productId
        && itemInventory(items, index).sku == items[index].variantSku
        && itemInventory(items, index).name == items[index].name
        && itemInventory(items, index).price == items[index].price
        && itemInventory(items, index).status == 'ACTIVE'
        && itemInventory(items, index).stock >= 0
        && itemInventory(items, index).lastOrderId == orderId
      );
    }

    function itemId(items, index) {
      return index < items.size() ? items[index].inventoryId : '';
    }

    function quantityFor(items, inventoryId) {
      return (items.size() > 0 && items[0].inventoryId == inventoryId ? items[0].quantity : 0)
        + (items.size() > 1 && items[1].inventoryId == inventoryId ? items[1].quantity : 0)
        + (items.size() > 2 && items[2].inventoryId == inventoryId ? items[2].quantity : 0)
        + (items.size() > 3 && items[3].inventoryId == inventoryId ? items[3].quantity : 0)
        + (items.size() > 4 && items[4].inventoryId == inventoryId ? items[4].quantity : 0);
    }

    function validCoupon(order) {
      let coupon = get(/databases/$(database)/documents/coupons/$(order.couponCode)).data;
      let calculated = coupon.discountType == 'PERCENTAGE'
        ? (order.subtotal * coupon.discountValue / 100)
        : coupon.discountValue;
      return coupon.code == order.couponCode
        && coupon.isActive == true
        && coupon.discountValue is int && coupon.discountValue > 0
        && coupon.minOrderValue <= order.subtotal
        && coupon.startsAt <= request.time && coupon.expiresAt > request.time
        && (coupon.maxUsage == null || coupon.usedCount < coupon.maxUsage)
        && order.discount == (calculated > order.subtotal ? order.subtotal : calculated);
    }

    function validOrder(orderId) {
      let order = request.resource.data;
      let items = order.items;
      let computedSubtotal = lineTotal(items, 0) + lineTotal(items, 1) + lineTotal(items, 2)
        + lineTotal(items, 3) + lineTotal(items, 4);
      let expectedShipping = computedSubtotal >= 5000 ? 0 : 250;
      return order.keys().hasOnly([
          'orderNumber', 'userId', 'email', 'phone', 'firstName', 'lastName', 'address',
          'city', 'state', 'postalCode', 'paymentMethod', 'paymentStatus', 'status', 'notes',
          'items', 'inventoryIds', 'subtotal', 'discount', 'shippingCost', 'total',
          'couponCode', 'createdAt', 'updatedAt'
        ])
        && order.userId == request.auth.uid
        && order.email == request.auth.token.email
        && validText(order.orderNumber, 5, 80)
        && validText(order.phone, 9, 30)
        && validText(order.firstName, 2, 80) && validText(order.lastName, 2, 80)
        && validText(order.address, 5, 300) && validText(order.city, 2, 100)
        && validText(order.state, 2, 100) && validText(order.postalCode, 3, 20)
        && validText(order.notes, 0, 500)
        && order.paymentMethod == 'COD' && order.paymentStatus == 'PENDING' && order.status == 'PENDING'
        && order.createdAt == request.time && order.updatedAt == request.time
        && items is list && items.size() >= 1 && items.size() <= 5
        && order.inventoryIds is list && order.inventoryIds.size() == items.size()
        && order.inventoryIds[0] == itemId(items, 0)
        && (items.size() < 2 || order.inventoryIds[1] == itemId(items, 1))
        && (items.size() < 3 || order.inventoryIds[2] == itemId(items, 2))
        && (items.size() < 4 || order.inventoryIds[3] == itemId(items, 3))
        && (items.size() < 5 || order.inventoryIds[4] == itemId(items, 4))
        && order.inventoryIds.toSet().size() == order.inventoryIds.size()
        && validOrderItem(items, 0, orderId) && validOrderItem(items, 1, orderId)
        && validOrderItem(items, 2, orderId) && validOrderItem(items, 3, orderId)
        && validOrderItem(items, 4, orderId)
        && order.subtotal == computedSubtotal
        && order.shippingCost == expectedShipping
        && ((order.couponCode == null && order.discount == 0) || validCoupon(order))
        && order.total == order.subtotal - order.discount + order.shippingCost;
    }

    match /products/{productId} {
      allow get: if resource.data.status == 'PUBLISHED' || admin();
      allow list: if admin() || resource.data.status == 'PUBLISHED';
      allow create, update, delete: if admin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if admin();
    }

    match /contentPages/{pageId} {
      allow get: if resource.data.isPublished == true || admin();
      allow list: if admin() || resource.data.isPublished == true;
      allow write: if admin();
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || admin());
      allow list: if admin();
      allow create: if signedIn() && request.auth.uid == userId
        && request.resource.data.role == 'CUSTOMER'
        && request.resource.data.email == request.auth.token.email;
      allow update: if admin() || (signedIn() && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone', 'updatedAt'])
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email);
      allow delete: if admin();
    }

    match /inventory/{inventoryId} {
      allow read: if true;
      allow create, delete: if admin();
      allow update: if admin() || (signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'lastOrderId', 'updatedAt'])
        && request.resource.data.lastOrderId is string
        && getAfter(/databases/$(database)/documents/orders/$(request.resource.data.lastOrderId)).data.userId == request.auth.uid
        && getAfter(/databases/$(database)/documents/orders/$(request.resource.data.lastOrderId)).data.inventoryIds.hasAny([inventoryId])
        && request.resource.data.stock == resource.data.stock
          - quantityFor(getAfter(/databases/$(database)/documents/orders/$(request.resource.data.lastOrderId)).data.items, inventoryId)
        && request.resource.data.stock >= 0
        && request.resource.data.updatedAt == request.time);
    }

    match /orders/{orderId} {
      allow create: if signedIn() && validOrder(orderId);
      allow get, list: if admin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if admin();
    }

    match /coupons/{couponId} {
      allow get: if true;
      allow list: if admin();
      allow create, delete: if admin();
      allow update: if admin() || (signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount', 'lastOrderId', 'updatedAt'])
        && request.resource.data.usedCount == resource.data.usedCount + 1
        && request.resource.data.updatedAt == request.time
        && getAfter(/databases/$(database)/documents/orders/$(request.resource.data.lastOrderId)).data.userId == request.auth.uid
        && getAfter(/databases/$(database)/documents/orders/$(request.resource.data.lastOrderId)).data.couponCode == couponId);
    }

    match /contactMessages/{messageId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'email', 'phone', 'subject', 'message', 'status', 'createdAt'])
        && validText(request.resource.data.name, 2, 100)
        && validText(request.resource.data.email, 5, 254)
        && validText(request.resource.data.phone, 0, 30)
        && validText(request.resource.data.subject, 2, 160)
        && validText(request.resource.data.message, 10, 5000)
        && request.resource.data.status == 'NEW'
        && request.resource.data.createdAt == request.time;
      allow read, update, delete: if admin();
    }

    match /newsletterSubscribers/{subscriberId} {
      allow create: if request.resource.data.keys().hasOnly(['email', 'status', 'createdAt'])
        && validText(request.resource.data.email, 5, 254)
        && request.resource.data.status == 'ACTIVE';
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'createdAt'])
        && request.resource.data.email == resource.data.email
        && request.resource.data.status == 'ACTIVE';
      allow read, delete: if admin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
