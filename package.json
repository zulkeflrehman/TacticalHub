{
  "name": "tecticalhub",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "overrides": {
    "@opentelemetry/core": "2.8.0",
    "postcss": "8.5.10",
    "uuid": "11.1.1"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "firebase emulators:start --only hosting",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "tsx --test tests/commerce.test.ts",
    "test:live": "tsx scripts/live-checkout-smoke.ts",
    "test:e2e": "node scripts/run-e2e.mjs",
    "deploy": "npm run build && firebase deploy --only hosting,firestore",
    "firebase:deploy-rules": "firebase deploy --only firestore",
    "firebase:seed": "tsx scripts/firebase-seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "firebase": "^12.16.0",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.82.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.2",
    "@emnapi/runtime": "^1.11.2",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "firebase-tools": "15.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
