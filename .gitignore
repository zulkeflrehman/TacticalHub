# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/

# next.js
/.next/
/out/
/.firebase/

# production
/build

# misc
.DS_Store
*.pem
firebase-service-account*.json
gha-creds-*.json
/.gcloud/
/.firebase-config/
/.tools/

# debug
npm-debug.log*
firebase-debug.log*
firestore-debug.log
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# e2e output artifacts
e2e-out.txt
e2e-results.txt

# cache
.cache/

# env files (can opt-in for committing if needed)
.env*
!.env.example
firebase-web-config.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
